{
  "manifest_version": 3,
  "name": "Roblox Theme Studio",
  "version": "1.0",
  "description": "Customize Roblox with your own colors, backgrounds, and more!",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://*.roblox.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["picker/picker.html", "picker/picker.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*.roblox.com/*"],
      "js": ["content/theme.js"],
      "css": ["content/theme.css"],
      "run_at": "document_start"
    }
  ]
}
